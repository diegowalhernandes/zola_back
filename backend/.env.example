# Local
DATABASE_URL=sqlite:///./zola.db
SECRET_KEY=troque-por-uma-chave-secreta-longa
FRONTEND_ORIGIN=http://localhost:5173
PUBLIC_API_BASE_URL=http://localhost:8000

# Produção (Render + Supabase) — configure no painel do Render
#
# 1. Supabase → Project Settings → Database → Connection string → URI
# 2. Mode: Transaction (porta 6543) — recomendado para Render
# 3. Troque postgresql:// por postgresql+psycopg://
# 4. Substitua [YOUR-PASSWORD] pela senha do banco (URL-encode se tiver $ ou @)
#
# Exemplo:
# DATABASE_URL=postgresql+psycopg://postgres.xxxxxxxxxxxx:SUA_SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
# SECRET_KEY=chave-longa-aleatoria
# FRONTEND_ORIGIN=https://seu-front.vercel.app
# PUBLIC_API_BASE_URL=https://zola-back.onrender.com
